# ─── نقلة — إعدادات البيئة ───
# محلياً: انسخ إلى .env.local
# على Vercel: أضف نفس المفاتيح من Project → Settings → Environment Variables

# mock = يعمل الآن بدون DB | supabase = بعد ربط المفاتيح
NEXT_PUBLIC_DATA_PROVIDER=mock
NEXT_PUBLIC_AUTH_PROVIDER=mock

# Supabase — املأها عند الربط ثم غيّر PROVIDER إلى supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=naqlah-dev-secret-change-in-production-2025
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
